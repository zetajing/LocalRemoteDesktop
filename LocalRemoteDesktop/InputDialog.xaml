<Window x:Class="LocalRemoteDesktop.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接远程电脑"
        Width="380"
        Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e"
        FontFamily="Microsoft YaHei, SimHei, sans-serif"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="PromptText" Text="IP 地址:" Foreground="#ccc" FontSize="14" Margin="0,0,0,10"/>
            <TextBox x:Name="InputBox" Text="" Background="#222" Foreground="#ddd"
                     BorderBrush="#444" FontSize="16" Padding="6"
                     PreviewTextInput="OnPreviewTextInput"
                     KeyDown="OnInputKeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="确定" Width="80" Height="30"
                        Background="#0f3460" Foreground="White" BorderThickness="0"
                        Margin="0,0,10,0" Cursor="Hand"
                        Click="OnOk"/>
                <Button Content="取消" Width="80" Height="30"
                        Background="#333" Foreground="#ccc" BorderThickness="0"
                        Cursor="Hand"
                        Click="OnCancel"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
