<Window x:Class="LocalRemoteDesktop.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="远程桌面控制"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        AllowDrop="True"
        DragOver="OnDragOver"
        Drop="OnDrop"
        KeyDown="OnKeyDown"
        KeyUp="OnKeyUp"
        PreviewKeyDown="OnPreviewKeyDown"
        Loaded="OnLoaded"
        Closed="OnClosed">

    <Grid>
        <!-- 远程画面 (填满整个窗口) -->
        <Image x:Name="RemoteImage"
               Stretch="Uniform"
               VerticalAlignment="Stretch"
               HorizontalAlignment="Stretch"/>

        <!-- 顶部半透明统计栏 (全屏+窗口化通用) -->
        <Border x:Name="StatsBar"
                VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Height="36" Background="#BB1a1a2e"
                Opacity="0" Visibility="Visible"
                Panel.ZIndex="20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0">
                <TextBlock x:Name="StatsFps" Foreground="#0f0"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="StatsBandwidth" Foreground="#ccc"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="StatsLatency" Foreground="#ccc"
                           FontSize="13" VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="StatsResolution" Foreground="#888"
                           FontSize="12" VerticalAlignment="Center"/>
                <Separator Background="#444" Margin="16,4" Width="1"/>
                <Button x:Name="BtnSendFile" Content="发送文件"
                        Background="#0f3460" Foreground="White" BorderThickness="0"
                        Padding="8,4" Margin="4,0" Cursor="Hand"
                        Click="OnSendFile"/>
                <Button x:Name="BtnToggleFullscreen" Content="⛶ 窗口化"
                        Background="#333" Foreground="#ccc" BorderThickness="0"
                        Padding="8,4" Margin="4,0" Cursor="Hand"
                        Click="OnToggleFullscreen"/>
                <TextBlock x:Name="FileStatusText" Foreground="#aaa" FontSize="12"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 连接状态 -->
        <TextBlock x:Name="StatusText"
                   Text="正在连接..."
                   Foreground="White" FontSize="18"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Panel.ZIndex="10"/>

        <!-- 底部提示 -->
        <TextBlock x:Name="BottomHint"
                   Text="F11 切换全屏  |  Esc 退出  |  Ctrl+F 发送文件  |  拖拽文件到窗口即可发送"
                   Foreground="#666" FontSize="13"
                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Margin="0,0,0,8" Panel.ZIndex="10"/>
    </Grid>
</Window>
